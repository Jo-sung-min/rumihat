# Copy this file to `.env` and fill in values for your local machine.
# Never commit `.env`, `apps/api/.env`, or `apps/web/.env.local`.

# PostgreSQL for Docker Compose
POSTGRES_DB=rumihat
POSTGRES_USER=rumihat
POSTGRES_PASSWORD=change-me

# Spring Boot datasource
DATABASE_URL=jdbc:postgresql://localhost:5432/rumihat
DATABASE_USERNAME=rumihat
DATABASE_PASSWORD=change-me

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Temporary admin login
ADMIN_EMAIL=admin@rumihat.local
ADMIN_PASSWORD=change-me

# OAuth redirect targets
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
FRONTEND_AUTH_SUCCESS_URL=http://localhost:3000/login
FRONTEND_AUTH_FAILURE_URL=http://localhost:3000/login?oauth=failed

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=change-me
GOOGLE_OAUTH_CLIENT_SECRET=change-me

# Kakao OAuth
KAKAO_OAUTH_CLIENT_ID=change-me
KAKAO_OAUTH_CLIENT_SECRET=change-me

# Next.js frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
